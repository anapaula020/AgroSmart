<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — " : "")Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
<div class="shell">

    <aside class="sidebar" id="sidebar">
        <div class="sidebar__brand">
            <span class="material-symbols-outlined">grid_view</span>
            <span class="brand-name">Admin</span>
        </div>
        <nav class="sidebar__nav">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" href="/">
                <span class="material-symbols-outlined">dashboard</span> Dashboard
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")" href="/api/v1/products">
                <span class="material-symbols-outlined">inventory_2</span> Produtos
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")" href="/api/v1/categories">
                <span class="material-symbols-outlined">category</span> Categorias
            </a>
            <div class="nav-divider"></div>
            <a class="nav-link" href="/swagger" target="_blank">
                <span class="material-symbols-outlined">api</span> API Docs
            </a>
            <a class="nav-link" href="/health">
                <span class="material-symbols-outlined">monitor_heart</span> Health
            </a>
        </nav>
        <div class="sidebar__footer">
            <span class="env-badge">@Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT")</span>
        </div>
    </aside>

    <div class="main">
        <header class="topbar">
            <button class="topbar__toggle" id="sidebarToggle">
                <span class="material-symbols-outlined">menu</span>
            </button>
            <h1 class="topbar__title">@ViewData["Title"]</h1>
        </header>
        <main class="content">
            @RenderBody()
        </main>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/admin.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
