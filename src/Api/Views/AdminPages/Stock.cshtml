@{
    ViewData["Title"] = "Estoque";
}

<div class="page-header">
    <div class="filter-bar">
        <select class="input" id="filterProp" onchange="loadStock()">
            <option value="">Todas as propriedades</option>
        </select>
        <label style="display:flex;align-items:center;gap:8px;color:var(--text-dim);font-size:13px">
            <input type="checkbox" id="filterLow" onchange="loadStock()" />
            Apenas estoque baixo
        </label>
    </div>
    <div class="page-header__actions">
        <button class="btn btn--ghost" onclick="openModal('modalMovement')">
            <span class="material-symbols-outlined">swap_vert</span> Movimentar
        </button>
        <button class="btn btn--primary" onclick="openModal('modalNewItem')">
            <span class="material-symbols-outlined">add</span> Novo Item
        </button>
    </div>
</div>

<div id="listWrap">
    <div class="loading-state"><span class="material-symbols-outlined spin">sync</span> Carregando...</div>
</div>

<!-- Modal novo item -->
<div class="modal" id="modalNewItem">
    <div class="modal__box">
        <h2 class="modal__title">Novo Item de Estoque</h2>
        <div class="form-grid">
            <div class="form-group form-group--full">
                <label class="label">Propriedade *</label>
                <select class="input" id="itemProp"><option value="">Selecione...</option></select>
            </div>
            <div class="form-group form-group--full">
                <label class="label">Produto *</label>
                <select class="input" id="itemProduct"><option value="">Selecione...</option></select>
            </div>
            <div class="form-group">
                <label class="label">Estoque Mínimo</label>
                <input class="input" id="itemMin" type="number" step="0.01" value="0" />
            </div>
            <div class="form-group">
                <label class="label">Custo Unitário</label>
                <input class="input" id="itemCost" type="number" step="0.01" value="0" />
            </div>
        </div>
        <div class="form-actions">
            <button class="btn btn--primary" onclick="createItem()">Criar</button>
            <button class="btn btn--ghost" onclick="closeModal('modalNewItem')">Cancelar</button>
        </div>
    </div>
</div>

<!-- Modal movimentação -->
<div class="modal" id="modalMovement">
    <div class="modal__box">
        <h2 class="modal__title">Movimentação de Estoque</h2>
        <div class="form-grid">
            <div class="form-group form-group--full">
                <label class="label">Item *</label>
                <select class="input" id="movItem"><option value="">Selecione...</option></select>
            </div>
            <div class="form-group">
                <label class="label">Tipo *</label>
                <select class="input" id="movType">
                    <option value="Entrada">Entrada</option>
                    <option value="Saida">Saída</option>
                    <option value="Ajuste">Ajuste</option>
                </select>
            </div>
            <div class="form-group">
                <label class="label">Quantidade *</label>
                <input class="input" id="movQty" type="number" step="0.01" placeholder="0.00" />
            </div>
            <div class="form-group form-group--full">
                <label class="label">Motivo</label>
                <input class="input" id="movReason" placeholder="Opcional" />
            </div>
        </div>
        <div class="form-actions">
            <button class="btn btn--primary" onclick="createMovement()">Confirmar</button>
            <button class="btn btn--ghost" onclick="closeModal('modalMovement')">Cancelar</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
let allItems = [];

async function init() {
    const [props, products] = await Promise.all([
        Auth.json('/api/v1/rural-properties') ?? [],
        Auth.json('/api/v1/input-products') ?? []
    ]);

    const propSel = document.getElementById('filterProp');
    const itemPropSel = document.getElementById('itemProp');
    (props||[]).forEach(p => {
        propSel.innerHTML += `<option value="${p.id}">${p.name}</option>`;
        itemPropSel.innerHTML += `<option value="${p.id}">${p.name}</option>`;
    });

    const itemProductSel = document.getElementById('itemProduct');
    (products||[]).forEach(p => {
        itemProductSel.innerHTML += `<option value="${p.id}">${p.name} (${p.type})</option>`;
    });

    await loadStock();
}

async function loadStock() {
    const propId = document.getElementById('filterProp').value;
    const lowOnly = document.getElementById('filterLow').checked;
    const url = '/api/v1/stock/items' + (propId ? `?propertyId=${propId}` : '');
    allItems = await Auth.json(url) ?? [];
    let items = lowOnly ? allItems.filter(i => i.isLow) : allItems;

    // Populate movement select
    const movSel = document.getElementById('movItem');
    movSel.innerHTML = '<option value="">Selecione...</option>' +
        allItems.map(i => `<option value="${i.id}">${i.property?.name} — ${i.inputProduct?.name} (${fmtNum(i.quantityInStock)} ${i.inputProduct?.unit})</option>`).join('');

    const wrap = document.getElementById('listWrap');
    if (!items.length) {
        wrap.innerHTML = `<div class="panel"><div class="empty">
            <span class="material-symbols-outlined">inventory_2</span>
            <p>Nenhum item encontrado</p></div></div>`;
        return;
    }
    wrap.innerHTML = `<div class="panel"><div class="panel__body panel__body--flush">
        <table class="table"><thead><tr>
            <th>Produto</th><th>Tipo</th><th>Propriedade</th><th>Qtd. Atual</th><th>Mínimo</th><th>Status</th>
        </tr></thead><tbody>${items.map(i => `<tr>
            <td class="td--name">${i.inputProduct?.name ?? '—'}</td>
            <td class="text-muted">${i.inputProduct?.type ?? '—'}</td>
            <td class="text-muted">${i.property?.name ?? '—'}</td>
            <td class="mono ${i.isLow ? 'text-warn' : ''}">${fmtNum(i.quantityInStock)} ${i.inputProduct?.unit ?? ''}</td>
            <td class="mono text-muted">${fmtNum(i.minimumStock)}</td>
            <td>${i.isLow
                ? '<span class="badge sev--high">Baixo</span>'
                : '<span class="badge badge--active">OK</span>'}</td>
        </tr>`).join('')}</tbody></table></div></div>`;
}

async function createItem() {
    const body = {
        propertyId: document.getElementById('itemProp').value,
        inputProductId: document.getElementById('itemProduct').value,
        minimumStock: parseFloat(document.getElementById('itemMin').value) || 0,
        unitCost: parseFloat(document.getElementById('itemCost').value) || 0,
    };
    const res = await Auth.fetch('/api/v1/stock/items', { method: 'POST', body: JSON.stringify(body) });
    if (res?.ok) { toast('Item criado!'); closeModal('modalNewItem'); await loadStock(); }
    else { const e = await res?.json(); toast(e?.message ?? 'Erro', 'error'); }
}

async function createMovement() {
    const itemId = document.getElementById('movItem').value;
    const body = {
        type: document.getElementById('movType').value,
        quantity: parseFloat(document.getElementById('movQty').value) || 0,
        reason: document.getElementById('movReason').value || null,
    };
    const res = await Auth.fetch(`/api/v1/stock/items/${itemId}/movements`, { method: 'POST', body: JSON.stringify(body) });
    if (res?.ok) {
        const d = await res.json();
        toast(`Movimentação registrada. Saldo: ${fmtNum(d.newBalance)}`);
        closeModal('modalMovement');
        await loadStock();
    } else { const e = await res?.json(); toast(e?.message ?? 'Erro', 'error'); }
}

init();
</script>
}
