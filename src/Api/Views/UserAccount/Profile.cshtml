@using Microsoft.AspNetCore.Identity
@model IdentityUser
@{
    ViewData["Title"] = "Minha Conta";
}

<div class="profile-page">

    <!-- ── Header ──────────────────────────────────────────────────── -->
    <div class="profile-header">
        <div class="profile-avatar">
            <span class="material-symbols-outlined">person</span>
        </div>
        <div class="profile-header__info">
            <h2 class="profile-header__email" id="displayEmail">@Model.Email</h2>
            <span class="profile-header__meta">
                ID: <code class="mono">@Model.Id</code>
            </span>
        </div>
    </div>

    <!-- ── Two-column grid ─────────────────────────────────────────── -->
    <div class="profile-grid">

        <!-- ── Dados da conta ──────────────────────────────────────── -->
        <div class="panel">
            <div class="panel__header">
                <span class="material-symbols-outlined">manage_accounts</span>
                <h3 class="panel__title">Dados da Conta</h3>
            </div>
            <div class="panel__body">

                <!-- E-mail -->
                <div class="field-group" id="emailSection">
                    <label class="field-label">E-mail</label>
                    <div class="field-row">
                        <input type="email" class="field-input" id="inputEmail"
                               value="@Model.Email" placeholder="seu@email.com" />
                        <button class="btn btn--accent" onclick="saveEmail()">
                            <span class="material-symbols-outlined">save</span>
                            Salvar
                        </button>
                    </div>
                    <span class="field-hint" id="emailHint"></span>
                </div>

                <div class="divider"></div>

                <!-- Senha -->
                <div class="field-group">
                    <label class="field-label">Alterar Senha</label>
                    <div class="field-stack">
                        <input type="password" class="field-input" id="inputCurrentPass"
                               placeholder="Senha atual" autocomplete="current-password" />
                        <input type="password" class="field-input" id="inputNewPass"
                               placeholder="Nova senha (mín. 6 caracteres)" autocomplete="new-password" />
                        <input type="password" class="field-input" id="inputConfirmPass"
                               placeholder="Confirmar nova senha" autocomplete="new-password" />
                        <button class="btn btn--primary" onclick="changePassword()">
                            <span class="material-symbols-outlined">lock_reset</span>
                            Atualizar senha
                        </button>
                    </div>
                    <span class="field-hint" id="passwordHint"></span>
                </div>

            </div>
        </div>

        <!-- ── Segurança / Info ─────────────────────────────────────── -->
        <div class="panel">
            <div class="panel__header">
                <span class="material-symbols-outlined">security</span>
                <h3 class="panel__title">Segurança</h3>
            </div>
            <div class="panel__body">
                <div class="security-row">
                    <span class="material-symbols-outlined security-icon security-icon--ok">verified_user</span>
                    <div>
                        <strong>Autenticação ativa</strong>
                        <p class="text-muted">Sua sessão está protegida via JWT.</p>
                    </div>
                </div>
                <div class="security-row">
                    <span class="material-symbols-outlined security-icon">key</span>
                    <div>
                        <strong>API Keys</strong>
                        <p class="text-muted">Gerencie suas chaves de acesso abaixo.</p>
                    </div>
                </div>
                <div class="security-row">
                    <span class="material-symbols-outlined security-icon">fingerprint</span>
                    <div>
                        <strong>Verificação de e-mail</strong>
                        <p class="text-muted">
                            @(Model.EmailConfirmed
                                ? "E-mail verificado."
                                : "E-mail ainda não verificado.")
                        </p>
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /profile-grid -->

    <!-- ── API Keys ─────────────────────────────────────────────────── -->
    <div class="panel api-keys-panel">
        <div class="panel__header">
            <span class="material-symbols-outlined">api</span>
            <h3 class="panel__title">API Keys</h3>
            <button class="btn btn--accent btn--sm panel__header-action" onclick="openCreateModal()">
                <span class="material-symbols-outlined">add</span>
                Nova chave
            </button>
        </div>
        <div class="panel__body">
            <p class="text-muted api-keys-desc">
                Use chaves de API para autenticar chamadas externas.
                O valor completo é exibido <strong>uma única vez</strong> no momento da criação.
            </p>
            <div class="table-wrap">
                <table class="data-table" id="keysTable">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Prefixo</th>
                            <th>Escopo</th>
                            <th>Status</th>
                            <th>Último uso</th>
                            <th>Expira em</th>
                            <th>Criada em</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="keysBody">
                        <tr id="keysLoading">
                            <td colspan="8" class="table-empty">
                                <span class="material-symbols-outlined spin">progress_activity</span>
                                Carregando chaves…
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div><!-- /profile-page -->

<!-- ── Modal: criar chave ──────────────────────────────────────────────── -->
<div class="modal-backdrop" id="createModal" style="display:none" onclick="closeCreateModal(event)">
    <div class="modal" onclick="event.stopPropagation()">
        <div class="modal__header">
            <h4 class="modal__title">
                <span class="material-symbols-outlined">add_circle</span>
                Nova API Key
            </h4>
            <button class="modal__close" onclick="closeCreateModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="modal__body">
            <div class="field-group">
                <label class="field-label">Nome da chave <span class="req">*</span></label>
                <input type="text" class="field-input" id="keyName"
                       placeholder="Ex: Integração ERP, App Mobile…" maxlength="100" />
            </div>
            <div class="field-group">
                <label class="field-label">Escopo</label>
                <select class="field-input" id="keyScope">
                    <option value="ReadOnly">ReadOnly — somente leitura</option>
                    <option value="ReadWrite">ReadWrite — leitura e escrita</option>
                    <option value="Admin">Admin — acesso total</option>
                </select>
            </div>
            <div class="field-group">
                <label class="field-label">Expira em <span class="field-optional">(opcional)</span></label>
                <input type="datetime-local" class="field-input" id="keyExpires" />
            </div>
            <div class="field-hint" id="createHint"></div>
        </div>
        <div class="modal__footer">
            <button class="btn btn--ghost" onclick="closeCreateModal()">Cancelar</button>
            <button class="btn btn--accent" onclick="createKey()">
                <span class="material-symbols-outlined">add</span>
                Gerar chave
            </button>
        </div>
    </div>
</div>

<!-- ── Modal: exibir chave criada ──────────────────────────────────────── -->
<div class="modal-backdrop" id="revealModal" style="display:none" onclick="closeRevealModal(event)">
    <div class="modal" onclick="event.stopPropagation()">
        <div class="modal__header">
            <h4 class="modal__title">
                <span class="material-symbols-outlined" style="color:var(--accent)">key</span>
                Chave gerada!
            </h4>
        </div>
        <div class="modal__body">
            <div class="key-reveal-banner">
                <span class="material-symbols-outlined">warning</span>
                Copie agora. Esta chave <strong>não será exibida novamente.</strong>
            </div>
            <label class="field-label">Sua chave de API</label>
            <div class="key-copy-row">
                <code class="key-value" id="revealKey"></code>
                <button class="btn btn--ghost btn--sm" onclick="copyKey()">
                    <span class="material-symbols-outlined" id="copyIcon">content_copy</span>
                </button>
            </div>
        </div>
        <div class="modal__footer">
            <button class="btn btn--accent" onclick="closeRevealModal()">Entendi, já copiei</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Inject fresh JWT from server so API calls work even after cookie expiry
    const _freshToken = '@ViewData["Token"]';
    if (_freshToken) { localStorage.setItem('jwt', _freshToken); }

    // ── Fetch helpers — usa Auth do admin.js (injeta Bearer token) ────────────
    async function post(url, body) {
        const res = await Auth.fetch(url, {
            method: 'POST',
            body: JSON.stringify(body)
        });
        if (!res) return { ok: false, error: 'Sessão expirada.' };
        const ct = res.headers.get('content-type') || '';
        if (!ct.includes('application/json'))
            return { ok: false, error: `Erro inesperado (HTTP ${res.status}).` };
        return res.json();
    }

    async function get(url) {
        const res = await Auth.fetch(url);
        if (!res) return null;
        const ct = res.headers.get('content-type') || '';
        if (!ct.includes('application/json')) return null;
        if (!res.ok) return null;
        return res.json();
    }

    // ── Hint helpers ──────────────────────────────────────────────────────────
    function hint(id, msg, ok) {
        const el = document.getElementById(id);
        el.textContent = msg;
        el.className = 'field-hint ' + (ok ? 'field-hint--ok' : 'field-hint--err');
        setTimeout(() => { el.textContent = ''; el.className = 'field-hint'; }, 4000);
    }

    // ── Save email ────────────────────────────────────────────────────────────
    async function saveEmail() {
        const newEmail = document.getElementById('inputEmail').value.trim();
        const res = await post('/account/update-email', { newEmail });
        if (res.ok) {
            document.getElementById('displayEmail').textContent = res.email;
            hint('emailHint', 'E-mail atualizado!', true);
        } else {
            hint('emailHint', res.error ?? 'Erro ao atualizar e-mail.', false);
        }
    }

    // ── Change password ───────────────────────────────────────────────────────
    async function changePassword() {
        const currentPassword = document.getElementById('inputCurrentPass').value;
        const newPassword     = document.getElementById('inputNewPass').value;
        const confirm         = document.getElementById('inputConfirmPass').value;

        if (newPassword !== confirm) { hint('passwordHint', 'As senhas não coincidem.', false); return; }
        if (newPassword.length < 6)  { hint('passwordHint', 'Mínimo de 6 caracteres.', false);  return; }

        const res = await post('/account/change-password', { currentPassword, newPassword });
        if (res.ok) {
            ['inputCurrentPass','inputNewPass','inputConfirmPass'].forEach(id => document.getElementById(id).value = '');
            hint('passwordHint', 'Senha alterada com sucesso!', true);
        } else {
            hint('passwordHint', res.error ?? 'Erro ao alterar senha.', false);
        }
    }

    // ── Load API keys ─────────────────────────────────────────────────────────
    async function loadKeys() {
        const tbody = document.getElementById('keysBody');
        const keys = await get('/account/apikeys');

        if (keys === null) {
            tbody.innerHTML = `<tr><td colspan="8" class="table-empty">Erro ao carregar chaves.</td></tr>`;
            return;
        }

        if (!Array.isArray(keys) || !keys.length) {
            tbody.innerHTML = `<tr><td colspan="8" class="table-empty">
                <span class="material-symbols-outlined">key_off</span>
                Nenhuma chave criada ainda.
            </td></tr>`;
            return;
        }

        const scopeLabel = { ReadOnly: 'ReadOnly', ReadWrite: 'ReadWrite', Admin: 'Admin' };
        const scopeClass = { ReadOnly: 'badge--muted', ReadWrite: 'badge--info', Admin: 'badge--warn' };

        tbody.innerHTML = keys.map(k => `
        <tr data-id="${k.id}" class="${k.isActive ? '' : 'row--disabled'}">
            <td class="td-name">${esc(k.name)}</td>
            <td><code class="mono">${esc(k.prefix)}…</code></td>
            <td><span class="badge ${scopeClass[k.scope] ?? ''}">${scopeLabel[k.scope] ?? k.scope}</span></td>
            <td>
                ${k.isActive
                    ? '<span class="badge badge--ok">Ativa</span>'
                    : '<span class="badge badge--danger">Inativa</span>'}
            </td>
            <td class="text-muted">${k.lastUsedAt ? fmtDate(k.lastUsedAt) : '—'}</td>
            <td class="text-muted">${k.expiresAt  ? fmtDate(k.expiresAt)  : 'Sem expiração'}</td>
            <td class="text-muted">${fmtDate(k.createdAt)}</td>
            <td class="td-actions">
                ${k.isActive ? `<button class="btn-icon" title="Desativar" onclick="deactivateKey('${k.id}', this)">
                    <span class="material-symbols-outlined">block</span>
                </button>` : ''}
                <button class="btn-icon btn-icon--danger" title="Excluir" onclick="deleteKey('${k.id}', this)">
                    <span class="material-symbols-outlined">delete</span>
                </button>
            </td>
        </tr>`).join('');
    }

    // ── Deactivate key ────────────────────────────────────────────────────────
    async function deactivateKey(id, btn) {
        if (!confirm('Desativar esta chave?')) return;
        const res = await post(`/account/apikeys/${id}/deactivate`, {});
        if (res.ok) loadKeys();
        else alert(res.error);
    }

    // ── Delete key ────────────────────────────────────────────────────────────
    async function deleteKey(id, btn) {
        if (!confirm('Excluir permanentemente esta chave?')) return;
        const res = await post(`/account/apikeys/${id}/delete`, {});
        if (res.ok) loadKeys();
        else alert(res.error);
    }

    // ── Create key modal ──────────────────────────────────────────────────────
    function openCreateModal() {
        document.getElementById('keyName').value = '';
        document.getElementById('keyScope').value = '0';
        document.getElementById('keyExpires').value = '';
        document.getElementById('createHint').textContent = '';
        document.getElementById('createModal').style.display = 'flex';
        setTimeout(() => document.getElementById('keyName').focus(), 50);
    }

    function closeCreateModal(e) {
        if (e && e.target !== document.getElementById('createModal')) return;
        document.getElementById('createModal').style.display = 'none';
    }

    async function createKey() {
        const name      = document.getElementById('keyName').value.trim();
        const scope     = document.getElementById('keyScope').value;
        const expiresAt = document.getElementById('keyExpires').value || null;
        const hintEl    = document.getElementById('createHint');

        if (name.length < 2) { hintEl.textContent = 'Nome muito curto.'; hintEl.className = 'field-hint field-hint--err'; return; }

        const res = await post('/account/apikeys', { name, scope, expiresAt });
        if (res.ok) {
            document.getElementById('createModal').style.display = 'none';
            document.getElementById('revealKey').textContent = res.rawKey;
            document.getElementById('copyIcon').textContent = 'content_copy';
            document.getElementById('revealModal').style.display = 'flex';
            loadKeys();
        } else {
            hintEl.textContent = res.error ?? 'Erro ao criar chave.';
            hintEl.className = 'field-hint field-hint--err';
        }
    }

    // ── Reveal modal ──────────────────────────────────────────────────────────
    function closeRevealModal(e) {
        if (e && e.target !== document.getElementById('revealModal')) return;
        document.getElementById('revealModal').style.display = 'none';
    }

    async function copyKey() {
        const key = document.getElementById('revealKey').textContent;
        await navigator.clipboard.writeText(key);
        document.getElementById('copyIcon').textContent = 'check';
        setTimeout(() => document.getElementById('copyIcon').textContent = 'content_copy', 2000);
    }

    // ── Utils — esc() local; fmtDate() herdado do admin.js ──────────────────
    function esc(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

    // ── Init ──────────────────────────────────────────────────────────────────
    loadKeys();

    // Keyboard shortcut: Esc closes modals
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            document.getElementById('createModal').style.display = 'none';
            document.getElementById('revealModal').style.display = 'none';
        }
    });
</script>
}
