{
  "App": {
    "Name": "My API",
    "Description": "REST API with .NET 8 and SQL Server"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlserver;Database=AppDb;User Id=sa;Password=Dev@1234!;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "super-secret-key-change-in-production-min-32-chars!!",
    "Issuer": "MyApi",
    "Audience": "MyApiUsers",
    "ExpiresHours": "8"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "OpenWeather": {
    "ApiKey": "",
    "BaseUrl": "https://api.openweathermap.org/data/2.5/"
  },
  "Ibge": {
    "BaseUrl": "https://servicodados.ibge.gov.br/api/v1"
  }
}